{
	"layer": "top",
	"position": "bottom",
	"height": 22,
	"modules-left": [
		"custom/power",
		"custom/arrow9",
		"sway/workspaces",
		"sway/mode",
		"custom/arrow10",
		"tray",
		"custom/notification"
	],
	"modules-center": ["sway/window"],
	"modules-right": [
		"disk",
		"custom/arrow3",
		"memory",
		"custom/arrow2",
		"cpu",
		"temperature",
		"custom/arrow1",
		"clock"
	],
	"custom/power": {
		"format": " пЊў ",
		"tooltip": false,
		"menu": "on-click",
		"menu-file": "$HOME/.config/waybar/power_menu.xml",
		"menu-actions": {
			"shutdown": "shutdown now",
			"reboot": "reboot now",
			"suspend": "systemctl suspend",
			"hibernate": "systemctl hibernate"
		}
	},
	"clock": {
		"interval": 10,
		"format": " {:%a %d/%m %H:%M} ",
		"tooltip": false
	},
	"cpu": {
		"interval": 5,
		"tooltip": false,
		"format": "п’ј   {usage}% ",
		"format-alt": "п’ј   {load} ",
		"states": {
			"warning": 70,
			"critical": 90
		}
	},
	"memory": {
		"interval": 5,
		"format": "у°Ќ›   {used:0.1f}G ",
		"states": {
			"warning": 70,
			"critical": 90
		},
		"tooltip": false
	},
	"disk": {
		"interval": 30,
		"format": "п‚    {free} "
		// "unit": "GB"
	},
	"sway/mode": {
		"format": "{}",
		"tooltip": false
	},
	"sway/window": {
		"format": "{title}",
		"max-length": 70,
		"tooltip": false,
		"rewrite": {
			".*вЂ” LibreWolf": "у°€№    LibreWolf",
			".*- Blender.*": "у°‚«    Blender",
			".*Godot.*": "о™џ    Godot",
			".*OBS.*": "    OBS Studio",
			"tmux": "п„     WezTerm",
			"zsh": "п„     WezTerm",
			"_zsh_tmux_plugin_run": "п„     WezTerm",
			"fastfetch": "п„     WezTerm",
			"steam": "п†¶    Steam",
			"pixieditor": "п‡ј    PixiEditor"
		}
	},
	"sway/workspaces": {
		"format": "{icon}",
		"format-window-separator": "о‚°",
		"on-click": "activate",
		"format-icons": {
			"1": "п„  ",
			"2": "о™џ ",
			"3": "п†¶ ",
			"9": "у±Ѓ© ",
			"urgent": "пЃЄ",
			"active": "п†’",
			"default": "п„‘"
		},
		// "persistent-workspaces": {
		// 	"2": [],
		// 	"3": []
		// },
		"sort-by-number": true
	},
	"temperature": {
		"thermal-zone": 1,
		"critical-threshold": 80,
		"interval": 30,
		"format": "{icon} {temperatureC}В° ",
		"format-icons": ["п‹‹", "п‹Љ", "п‹‰", "п‹€", "п‹‡"],
		"tooltip": false
	},
	"tray": {
		"icon-size": 18,
		"spacing": 10,
		"on-click": "activate"
	},
	"custom/notification": {
		"tooltip": false,
		"format": "{icon} {0}",
		"format-icons": {
			"notification": "у±…«",
			"none": "пѓі",
			"dnd-notification": "п‡¶ ",
			"dnd-none": "у°‚›",
			"inhibited-notification": "п‚ў ",
			"inhibited-none": "п‚ў",
			"dnd-inhibited-notification": "п‡· ",
			"dnd-inhibited-none": "п‡· "
		},
		"return-type": "json",
		"exec-if": "which swaync-client",
		"exec": "swaync-client -swb",
		// "on-click": "sleep 0.1 && swaync-client -t -sw",
		"on-click": "swaync-client -t -sw",
		// "on-click-right": "sleep 0.1 && swaync-client -d -sw",
		"on-click-right": "swaync-client -d -sw",
		"escape": true
	},
	"custom/arrow1": {
		"format": "о‚І",
		"tooltip": false
	},
	"custom/arrow2": {
		"format": "о‚І",
		"tooltip": false
	},
	"custom/arrow3": {
		"format": "о‚І",
		"tooltip": false
	},
	"custom/arrow4": {
		"format": "о‚І",
		"tooltip": false
	},
	"custom/arrow5": {
		"format": "о‚І",
		"tooltip": false
	},
	"custom/arrow6": {
		"format": "о‚І",
		"tooltip": false
	},
	"custom/arrow7": {
		"format": "о‚І",
		"tooltip": false
	},
	"custom/arrow8": {
		"format": "о‚І",
		"tooltip": false
	},
	"custom/arrow9": {
		"format": "о‚°",
		"on-click": "activate",
		"tooltip": false
	},
	"custom/arrow10": {
		"format": "о‚°",
		"tooltip": false
	}
}
