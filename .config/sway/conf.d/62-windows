## Sway idle inhibitor exceptions
# Steam
for_window [class="^steam_app_.*"] inhibit_idle focus
for_window [app_id="^steam_app_.*"] inhibit_idle focus
for_window [class="Steam"] inhibit_idle focus
for_window [app_id="steam"] inhibit_idle focus

for_window [app_id=".*[Dd]iablo.*"] inhibit_idle focus

# Lutris
for_window [class="lutris"] inhibit_idle focus
for_window [app_id="lutris"] inhibit_idle focus

# Heroic Games Launcher
for_window [class="heroic"] inhibit_idle focus
for_window [app_id="heroic"] inhibit_idle focus

# GameHub
for_window [class="GameHub"] inhibit_idle focus
for_window [app_id="gamehub"] inhibit_idle focus

# Wine and Proton games
for_window [title=".*Wine.*"] inhibit_idle focus
for_window [class="wine"] inhibit_idle focus
for_window [instance="wine"] inhibit_idle focus

# RetroArch
for_window [instance="retroarch"] inhibit_idle focus

# Minecraft Launcher and game
for_window [class=".*[Mm]inecraft.*"] inhibit_idle focus

# Icarus game
for_window [app_id=".*[Ii]carus.*"] inhibit_idle focus

# Window idle inhibitor rules for Stremio
for_window [class=".*[Ss]tremio.*"] inhibit_idle focus
for_window [title=".*[Ss]tremio.*"] inhibit_idle focus
for_window [app_id=".*[Ss]tremio.*"] inhibit_idle focus

# Window idle inhibitor rules for Ardour Digital Audio Workstation
for_window [instance="ardour_ardour"] inhibit_idle focus
for_window [class="Ardour"] inhibit_idle focus
for_window [title=".*Ardour.*"] inhibit_idle focus

# Window rules for Thunar
for_window [app_id="thunar" title="Rename .*"] floating enable

